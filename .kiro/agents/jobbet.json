        "\\Aless\\b.*\\z",
        "\\Atail\\b.*\\z",
        "\\Agrep\\b.*\\z",
        "\\Acurl\\b.*\\z",
        "\\Ajq\\b.*\\z",
        "\\Aaws\\b.*\\z",
        "\\Achmod\\b.*\\z",
        "\\Acat\\b.*\\z",
        "\\Ahead\\b.*\\z",
        "\\Apwd\\z",
        "\\Amkdir\\b.*\\z",
        "\\Apython3\\b.*\\z",
        "\\Apip3\\b.*\\z",
        "\\A\\./deploy\\.sh\\b.*\\z",
        "\\A\\./setup-infrastructure\\.sh\\b.*\\z",
        "\\A\\./kiro\\.sh\\b.*\\z"
